# Sanity CMS Configuration
# Get these from https://www.sanity.io/manage
PUBLIC_SANITY_PROJECT_ID=your-project-id
PUBLIC_SANITY_DATASET=production
# Create a read token at https://www.sanity.io/manage/project/YOUR_PROJECT_ID/api#tokens
SANITY_API_TOKEN=your-read-token

# Contact Form
# Turnstile site key from https://dash.cloudflare.com/?to=/:account/turnstile
PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
# Email handler worker URL
PUBLIC_CONTACT_API_URL=https://email.omnibrand.cloud/api/contact
# Site key matching the KV config entry (site:xxx)
PUBLIC_CONTACT_SITE_KEY=omnibrand
