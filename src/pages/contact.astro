---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const TURNSTILE_SITE_KEY = '0x4AAAAAAC8BZElHyToptVJa';
const CONTACT_API_URL = 'https://email.omnibrand.cloud/api/contact';
const SITE_KEY = 'omnibrand';
---

<BaseLayout title="Contact Us — OmniBrand" description="Get in touch with OmniBrand. Book a free discovery call or send us a message about your brand design project.">
  <Header />
  <main class="contact-page">

    <section class="contact-hero">
      <div class="container">
        <p class="contact-hero__eyebrow">Get in Touch</p>
        <h1 class="contact-hero__title">Let's talk about your brand.</h1>
        <p class="contact-hero__subtitle">Whether you're ready to start a project or just exploring your options, we'd love to hear from you.</p>
      </div>
    </section>

    <section class="contact-main section">
      <div class="container">
        <div class="contact-grid">

          <div class="contact-form-wrap">
            <h2 class="contact-form__title">Send us a message</h2>

            <!-- Success message (hidden by default) -->
            <div class="contact-form__success" id="form-success" hidden>
              <div class="contact-form__success-icon" aria-hidden="true">✓</div>
              <h3>Message sent!</h3>
              <p>Thanks for reaching out. We'll get back to you within 1–2 business days.</p>
            </div>

            <!-- Error message (hidden by default) -->
            <div class="contact-form__error" id="form-error" hidden>
              <p id="form-error-text">Something went wrong. Please try again or email us directly.</p>
            </div>

            <form class="contact-form" id="contact-form"
              data-api-url={CONTACT_API_URL}
              data-site-key={SITE_KEY}>

              <!-- Honeypot — hidden from humans -->
              <div class="contact-form__honey" aria-hidden="true">
                <input type="text" name="_honey" tabindex="-1" autocomplete="off" />
              </div>

              <div class="contact-form__row">
                <div class="contact-form__field">
                  <label for="first-name">First Name</label>
                  <input type="text" id="first-name" name="first-name" required />
                </div>
                <div class="contact-form__field">
                  <label for="last-name">Last Name</label>
                  <input type="text" id="last-name" name="last-name" required />
                </div>
              </div>

              <div class="contact-form__field">
                <label for="email">Email <span class="required">(Required)</span></label>
                <input type="email" id="email" name="email" required />
              </div>

              <div class="contact-form__field">
                <label for="location">Where are you based?</label>
                <input type="text" id="location" name="location" placeholder="Country, City" />
              </div>

              <div class="contact-form__field">
                <label for="project">Please tell us all about your project</label>
                <textarea id="project" name="project" rows="5" placeholder="What do you have in mind?" required></textarea>
              </div>

              <div class="contact-form__field">
                <label for="referral">Were you referred to us?</label>
                <input type="text" id="referral" name="referral" placeholder="If so, who do we have to thank?" />
              </div>

              <div class="contact-form__checkbox">
                <input type="checkbox" id="consent" name="consent" required />
                <label for="consent">I consent to having this website store my submitted information for the purposes of responding to my enquiry.</label>
              </div>

              <!-- Turnstile widget -->
              <div class="cf-turnstile" data-sitekey={TURNSTILE_SITE_KEY} data-theme="light"></div>

              <button type="submit" class="btn btn--primary btn--lg" id="submit-btn">
                <span class="btn__text" id="btn-text">Submit</span>
                <span class="btn__loading" id="btn-loading" style="display:none;">Sending...</span>
              </button>
            </form>
          </div>

          <div class="contact-info">
            <div class="contact-info__block">
              <h3>Email</h3>
              <ul>
                <li><a href="mailto:info@omnibrand.co.nz">info@omnibrand.co.nz</a></li>
                <li><a href="mailto:support@omnibrand.co.nz">support@omnibrand.co.nz</a></li>
                <li><a href="mailto:accounts@omnibrand.co.nz">accounts@omnibrand.co.nz</a></li>
              </ul>
            </div>

            <div class="contact-info__block">
              <h3>Phone</h3>
              <ul>
                <li>Office: <a href="tel:+6448880212">+64 4 888 0212</a></li>
                <li>Mobile: <a href="tel:+642041435060">+64 20 4143 5060</a></li>
              </ul>
            </div>

            <div class="contact-info__block">
              <h3>Location</h3>
              <p>Level 2, Bell Gully Building,<br />40 Lady Elizabeth Lane,<br />Wellington Central, Wellington 6011</p>
            </div>

            <div class="contact-info__block">
              <h3>Working with us</h3>
              <p>We are based in beautiful Wellington, New Zealand, but our clients are all over the world, from New York to Seoul, London to Cape Town, and from San Francisco to right here in New Zealand's coolest little capital.</p>
            </div>
          </div>

        </div>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>

<!-- Turnstile script -->
<script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const btnText = document.getElementById('btn-text') as HTMLElement;
  const btnLoading = document.getElementById('btn-loading') as HTMLElement;
  const successEl = document.getElementById('form-success') as HTMLElement;
  const errorEl = document.getElementById('form-error') as HTMLElement;
  const errorText = document.getElementById('form-error-text') as HTMLElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Reset states
    errorEl.hidden = true;
    submitBtn.disabled = true;
    btnText.style.display = 'none';
    btnLoading.style.display = 'inline';

    const formData = new FormData(form);
    const apiUrl = form.dataset.apiUrl!;
    const siteKey = form.dataset.siteKey!;

    // Get Turnstile token
    const turnstileToken = formData.get('cf-turnstile-response') as string;
    if (!turnstileToken) {
      errorText.textContent = 'Please complete the verification challenge.';
      errorEl.hidden = false;
      submitBtn.disabled = false;
      btnText.style.display = 'inline';
      btnLoading.style.display = 'none';
      return;
    }

    // Build payload matching ContactFormData interface
    const firstName = (formData.get('first-name') as string || '').trim();
    const lastName = (formData.get('last-name') as string || '').trim();

    const payload = {
      siteKey,
      name: `${firstName} ${lastName}`.trim(),
      email: (formData.get('email') as string || '').trim(),
      message: [
        formData.get('project') as string || '',
        formData.get('location') ? `\n\nLocation: ${formData.get('location')}` : '',
        formData.get('referral') ? `\nReferred by: ${formData.get('referral')}` : '',
      ].join(''),
      turnstileToken,
      _honey: (formData.get('_honey') as string) || undefined,
    };

    try {
      const res = await fetch(apiUrl, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      const data = await res.json();

      if (res.ok && data.success) {
        form.hidden = true;
        successEl.hidden = false;
      } else {
        errorText.textContent = data.error || 'Something went wrong. Please try again or email us directly.';
        errorEl.hidden = false;
        // Reset Turnstile for retry
        if (window.turnstile) {
          window.turnstile.reset();
        }
      }
    } catch {
      errorText.textContent = 'Network error. Please check your connection and try again.';
      errorEl.hidden = false;
    } finally {
      submitBtn.disabled = false;
      btnText.style.display = 'inline';
      btnLoading.style.display = 'none';
    }
  });
</script>

<style>
  /* =====================
     HERO
     ===================== */
  .contact-hero {
    background: linear-gradient(160deg, #14282d 0%, #264047 40%, #071114 100%);
    padding: var(--space-3xl) 0;
    text-align: center;
  }

  .contact-hero__eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-bottom: var(--space-md);
  }

  .contact-hero__title {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4vw, 3rem);
    color: var(--color-white);
    line-height: 1.3;
    margin-bottom: var(--space-md);
  }

  .contact-hero__subtitle {
    font-size: 1.05rem;
    color: var(--color-mid-grey);
    line-height: 1.8;
    max-width: 550px;
    margin-inline: auto;
  }

  /* =====================
     MAIN GRID
     ===================== */
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: var(--space-3xl);
    align-items: start;
  }

  /* =====================
     FORM
     ===================== */
  .contact-form__title {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    color: var(--color-deep-teal);
    margin-bottom: var(--space-lg);
  }

  .contact-form__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md);
  }

  .contact-form__field {
    margin-bottom: var(--space-md);
  }

  .contact-form__field label {
    display: block;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-deep-teal);
    margin-bottom: 0.4rem;
  }

  .contact-form__field .required {
    font-weight: 400;
    color: var(--color-warm-neutral);
    font-size: 0.8rem;
  }

  .contact-form__field input,
  .contact-form__field textarea {
    width: 100%;
    padding: 0.75rem 1rem;
    font-family: var(--font-sans);
    font-size: 0.95rem;
    color: var(--color-dark-grey);
    background: var(--color-white);
    border: 1px solid var(--color-light-grey);
    border-radius: 6px;
    transition: border-color var(--transition-fast);
  }

  .contact-form__field input:focus,
  .contact-form__field textarea:focus {
    outline: none;
    border-color: var(--color-gold);
  }

  .contact-form__field textarea {
    resize: vertical;
    min-height: 120px;
  }

  .contact-form__checkbox {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
    margin-bottom: var(--space-lg);
  }

  .contact-form__checkbox input[type="checkbox"] {
    margin-top: 0.2rem;
    flex-shrink: 0;
    width: 18px;
    height: 18px;
    accent-color: var(--color-accent);
  }

  .contact-form__checkbox label {
    font-size: 0.85rem;
    color: var(--color-warm-neutral);
    line-height: 1.6;
    cursor: pointer;
  }

  /* Honeypot — completely hidden */
  .contact-form__honey {
    position: absolute;
    left: -9999px;
    opacity: 0;
    height: 0;
    overflow: hidden;
  }

  /* Turnstile widget spacing */
  .cf-turnstile {
    margin-bottom: var(--space-lg);
  }

  /* Submit button states */
  .btn__loading {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  button:disabled {
    opacity: 0.7;
    cursor: not-allowed;
  }

  /* Success message */
  .contact-form__success {
    text-align: center;
    padding: var(--space-xl) var(--space-lg);
    background: #f0faf4;
    border: 1px solid #c6f0d5;
    border-radius: 12px;
  }

  .contact-form__success-icon {
    width: 48px;
    height: 48px;
    background: #16a34a;
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    font-weight: 700;
    margin: 0 auto var(--space-md);
  }

  .contact-form__success h3 {
    font-family: var(--font-serif);
    font-size: 1.3rem;
    color: var(--color-deep-teal);
    margin-bottom: var(--space-xs);
  }

  .contact-form__success p {
    color: var(--color-warm-neutral);
    font-size: 0.95rem;
  }

  /* Error message */
  .contact-form__error {
    padding: var(--space-sm) var(--space-md);
    background: #fef2f2;
    border: 1px solid #fecaca;
    border-radius: 8px;
    margin-bottom: var(--space-md);
  }

  .contact-form__error p {
    color: #dc2626;
    font-size: 0.9rem;
  }

  /* =====================
     CONTACT INFO SIDEBAR
     ===================== */
  .contact-info {
    background: var(--color-off-white);
    border-radius: 16px;
    padding: var(--space-xl);
  }

  .contact-info__block {
    margin-bottom: var(--space-lg);
  }

  .contact-info__block:last-child {
    margin-bottom: 0;
  }

  .contact-info__block h3 {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-deep-teal);
    margin-bottom: 0.5rem;
  }

  .contact-info__block ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .contact-info__block li,
  .contact-info__block p {
    font-size: 0.9rem;
    color: var(--color-dark-grey);
    line-height: 1.7;
  }

  .contact-info__block a {
    color: var(--color-deep-teal);
    transition: color var(--transition-fast);
  }

  .contact-info__block a:hover {
    color: var(--color-accent);
  }

  /* =====================
     RESPONSIVE
     ===================== */
  @media (max-width: 768px) {
    .contact-hero {
      padding-top: var(--space-xl);
    }

    .contact-grid {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }

    .contact-form__row {
      grid-template-columns: 1fr;
    }
  }
</style>
