---
---

<section class="hero">
  <div class="hero__bg-text" aria-hidden="true">OMNIBRAND</div>
  <div class="hero__inner container">
    <div class="hero__content">
      <p class="hero__eyebrow">Brand Design Studio</p>
      <h1 class="hero__title">
        Thoughtful brand design that reflects
        <span class="hero__title-accent">who you are</span>
        and what you offer
      </h1>
      <p class="hero__subtitle">
        Led by award-winning brand designer, Tara Slade, we help founders
        create brands that align with their vision and grow with them.
      </p>
      <div class="hero__actions">
        <a href="#contact" class="btn btn--primary">Book a Discovery Call</a>
        <a href="#services" class="btn btn--outline hero__btn-outline">Our Services</a>
      </div>
    </div>
    <div class="hero__visual">
      <div class="hero__image-frame">
        <div class="hero__image-placeholder">
          <!-- Replace with actual hero image -->
          <div class="hero__abstract">
            <div class="hero__orb hero__orb--1"></div>
            <div class="hero__orb hero__orb--2"></div>
            <div class="hero__orb hero__orb--3"></div>
          </div>
        </div>
      </div>
      <div class="hero__stat">
        <span class="hero__stat-number">100+</span>
        <span class="hero__stat-label">Brands Launched</span>
      </div>
    </div>
  </div>
  <div class="hero__scroll-hint" aria-hidden="true">
    <span></span>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    background: linear-gradient(160deg, var(--color-deep-teal) 0%, #1c3b43 40%, #1a363d 100%);
    overflow: hidden;
    padding-top: 80px;
  }

  .hero__bg-text {
    position: absolute;
    bottom: -3%;
    left: -2%;
    font-family: var(--font-serif);
    font-size: clamp(6rem, 15vw, 14rem);
    font-weight: 700;
    color: rgba(255, 255, 255, 0.03);
    letter-spacing: 0.05em;
    white-space: nowrap;
    user-select: none;
    pointer-events: none;
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl);
    align-items: center;
    padding-block: var(--space-xl);
    position: relative;
    z-index: 1;
  }

  .hero__eyebrow {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-bottom: var(--space-md);
  }

  .hero__title {
    color: var(--color-white);
    font-size: clamp(2.2rem, 4.5vw, 3.2rem);
    line-height: 1.2;
    margin-bottom: var(--space-md);
  }

  .hero__title-accent {
    color: var(--color-gold-light);
    font-style: italic;
  }

  .hero__subtitle {
    color: var(--color-mid-grey);
    font-size: 1.05rem;
    line-height: 1.8;
    margin-bottom: var(--space-lg);
    max-width: 50ch;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .hero__btn-outline {
    border-color: rgba(255, 255, 255, 0.3);
    color: var(--color-white);
  }

  .hero__btn-outline:hover {
    background-color: rgba(255, 255, 255, 0.1);
    border-color: var(--color-white);
    color: var(--color-white);
  }

  /* Visual / Abstract Art Side */
  .hero__visual {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .hero__image-frame {
    width: 100%;
    aspect-ratio: 4 / 5;
    max-width: 420px;
    border-radius: 200px 200px 40px 40px;
    overflow: hidden;
    position: relative;
  }

  .hero__image-placeholder {
    width: 100%;
    height: 100%;
    position: relative;
    background: linear-gradient(135deg, var(--color-teal-dark) 0%, #0d1e22 100%);
  }

  .hero__abstract {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .hero__orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(40px);
    animation: float 8s ease-in-out infinite;
  }

  .hero__orb--1 {
    width: 200px;
    height: 200px;
    background: var(--color-berry);
    opacity: 0.4;
    top: 15%;
    left: 10%;
    animation-delay: 0s;
  }

  .hero__orb--2 {
    width: 160px;
    height: 160px;
    background: var(--color-gold);
    opacity: 0.35;
    top: 45%;
    right: 10%;
    animation-delay: -3s;
  }

  .hero__orb--3 {
    width: 120px;
    height: 120px;
    background: var(--color-teal-accent);
    opacity: 0.3;
    bottom: 15%;
    left: 25%;
    animation-delay: -5s;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0) scale(1); }
    33% { transform: translateY(-20px) scale(1.05); }
    66% { transform: translateY(10px) scale(0.95); }
  }

  .hero__stat {
    position: absolute;
    bottom: 10%;
    right: 0;
    background: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    padding: var(--space-md) var(--space-lg);
    text-align: center;
  }

  .hero__stat-number {
    display: block;
    font-family: var(--font-display);
    font-size: 2.5rem;
    font-weight: 300;
    color: var(--color-gold-light);
    line-height: 1;
  }

  .hero__stat-label {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.6);
    margin-top: 0.25rem;
    display: block;
  }

  /* Scroll hint */
  .hero__scroll-hint {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
  }

  .hero__scroll-hint span {
    display: block;
    width: 1px;
    height: 48px;
    background: linear-gradient(to bottom, var(--color-gold), transparent);
    animation: scrollHint 2s ease-in-out infinite;
  }

  @keyframes scrollHint {
    0% { opacity: 1; transform: scaleY(0); transform-origin: top; }
    50% { opacity: 1; transform: scaleY(1); transform-origin: top; }
    50.1% { transform-origin: bottom; }
    100% { opacity: 0; transform: scaleY(0); transform-origin: bottom; }
  }

  @media (max-width: 768px) {
    .hero {
      min-height: auto;
      padding-block: 120px var(--space-3xl);
    }

    .hero__inner {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .hero__subtitle {
      margin-inline: auto;
    }

    .hero__actions {
      justify-content: center;
    }

    .hero__visual {
      display: none;
    }
  }
</style>
