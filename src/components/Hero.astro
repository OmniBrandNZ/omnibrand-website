---

<section class="hero">
  <div class="hero__bg-text" aria-hidden="true">OMNIBRAND</div>
  <div class="hero__bg-text hero__bg-text--bottom" aria-hidden="true">OMNIBRAND</div>
  <div class="hero__inner">
    <div class="hero__content">
      <p class="hero__eyebrow">Brand Design Studio</p>
      <h1 class="hero__title">
        Thoughtful brand design that reflects
        <span class="hero__title-accent">who you are</span>
        and what you offer
      </h1>
      <p class="hero__subtitle">
        Led by award-winning brand designer, Tara Slade, we've helped founders
        create brands that align with their vision and grow with them.
        Now, we'd love to help you.
      </p>
      <div class="hero__actions">
        <a href="#contact" class="btn btn--primary">Chat with Us</a>
        <a href="#services" class="btn btn--outline hero__btn-outline">Our Services</a>
      </div>
    </div>
    <div class="hero__visual">
      <img
        src="/images/tara-slade-brand-designer-wellington-new-zealand.jpg"
        alt="Tara Slade, OmniBrand founder"
        class="hero__photo"
      />
      <div class="hero__photo-overlay"></div>
      <div class="hero__stat">
        <span class="hero__stat-number">100+</span>
        <span class="hero__stat-label">Brands Launched</span>
      </div>
    </div>
  </div>
  <div class="hero__scroll-hint" aria-hidden="true">
    <span></span>
  </div>
</section>

<script>
  // Parallax on scroll
  const hero = document.querySelector('.hero');
  const bgTexts = document.querySelectorAll('.hero__bg-text');
  const content = document.querySelector('.hero__content');
  const visual = document.querySelector('.hero__visual');

  let ticking = false;

  function onScroll() {
    if (!ticking) {
      requestAnimationFrame(() => {
        const scrollY = window.scrollY;
        const heroHeight = hero?.offsetHeight || 1;

        if (scrollY < heroHeight) {
          const progress = scrollY / heroHeight;

          bgTexts.forEach((el, i) => {
            const dir = i === 0 ? 1 : -1;
            (el as HTMLElement).style.transform = `translateX(${dir * progress * 60}px)`;
          });

          if (content) {
            (content as HTMLElement).style.transform = `translateY(${progress * 40}px)`;
            (content as HTMLElement).style.opacity = `${1 - progress * 0.6}`;
          }

          if (visual) {
            (visual as HTMLElement).style.transform = `translateY(${progress * 20}px)`;
          }
        }

        ticking = false;
      });
      ticking = true;
    }
  }

  window.addEventListener('scroll', onScroll, { passive: true });
</script>

<style>
  /* --- Entrance animations --- */
  @keyframes fadeSlideUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeSlideIn {
    from {
      opacity: 0;
      transform: translateX(40px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  @keyframes gradientShift {
    0%   { background-position: 0% 50%; }
    50%  { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  @keyframes bgTextDrift {
    0%, 100% { transform: translateX(0); }
    50% { transform: translateX(30px); }
  }

  @keyframes float {
    0%, 100% { transform: translateY(0) scale(1); }
    33% { transform: translateY(-20px) scale(1.05); }
    66% { transform: translateY(10px) scale(0.95); }
  }

  @keyframes scrollHint {
    0% { opacity: 1; transform: scaleY(0); transform-origin: top; }
    50% { opacity: 1; transform: scaleY(1); transform-origin: top; }
    50.1% { transform-origin: bottom; }
    100% { opacity: 0; transform: scaleY(0); transform-origin: bottom; }
  }

  /* --- Hero section --- */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    background: linear-gradient(160deg, #0d1e24 0%, #14282d 30%, #0d1e24 60%, #08171b 100%);
    background-size: 200% 200%;
    animation: gradientShift 12s ease-in-out infinite;
    overflow: hidden;
  }

  /* Watermark text */
  .hero__bg-text {
    position: absolute;
    bottom: -3%;
    left: -2%;
    font-family: var(--font-serif);
    font-size: clamp(6rem, 15vw, 14rem);
    font-weight: 700;
    color: rgba(255, 255, 255, 0.03);
    letter-spacing: 0.05em;
    white-space: nowrap;
    user-select: none;
    pointer-events: none;
    animation: bgTextDrift 20s ease-in-out infinite;
    will-change: transform;
  }

  .hero__bg-text--bottom {
    bottom: auto;
    top: -2%;
    left: auto;
    right: -2%;
    font-size: clamp(5rem, 12vw, 11rem);
    animation-direction: reverse;
    animation-duration: 25s;
  }

  /* Layout */
  .hero__inner {
    display: grid;
    grid-template-columns: 1fr 40vw;
    min-height: 100vh;
    position: relative;
    z-index: 1;
  }

  .hero__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-block: var(--space-3xl);
    padding-left: max(clamp(1.25rem, 4vw, 2.5rem), calc((100vw - var(--max-width)) / 2 + clamp(1.25rem, 4vw, 2.5rem)));
    padding-right: var(--space-3xl);
  }

  /* --- Content entrance animations --- */
  .hero__eyebrow {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-bottom: var(--space-md);
    opacity: 0;
    animation: fadeSlideUp 0.8s var(--ease-smooth) 0.2s forwards;
  }

  .hero__title {
    color: var(--color-white);
    font-size: clamp(2.2rem, 4.5vw, 3.2rem);
    line-height: 1.2;
    margin-bottom: var(--space-md);
    opacity: 0;
    animation: fadeSlideUp 0.8s var(--ease-smooth) 0.4s forwards;
  }

  .hero__title-accent {
    color: var(--color-gold-light);
    font-style: italic;
  }

  .hero__subtitle {
    color: var(--color-mid-grey);
    font-size: 1.05rem;
    line-height: 1.8;
    margin-bottom: var(--space-lg);
    max-width: 50ch;
    opacity: 0;
    animation: fadeSlideUp 0.8s var(--ease-smooth) 0.6s forwards;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    opacity: 0;
    animation: fadeSlideUp 0.8s var(--ease-smooth) 0.8s forwards;
  }

  .hero__btn-outline {
    border-color: rgba(255, 255, 255, 0.3);
    color: var(--color-white);
  }

  .hero__btn-outline:hover {
    background-color: rgba(255, 255, 255, 0.1);
    border-color: var(--color-white);
    color: var(--color-white);
  }

  /* --- Visual / Photo side --- */
  .hero__visual {
    position: relative;
    overflow: hidden;
    opacity: 0;
    animation: fadeSlideIn 1s var(--ease-smooth) 0.5s forwards;
    will-change: transform;
  }

  .hero__photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  .hero__photo-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      rgba(13, 30, 36, 0.6) 0%,
      transparent 30%
    );
    pointer-events: none;
  }

  /* Stat badge */
  .hero__stat {
    position: absolute;
    bottom: 2rem;
    left: 2rem;
    background: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    padding: var(--space-md) var(--space-lg);
    text-align: center;
    opacity: 0;
    animation: fadeSlideUp 0.6s var(--ease-smooth) 1.2s forwards;
  }

  .hero__stat-number {
    display: block;
    font-family: var(--font-display);
    font-size: 2.5rem;
    font-weight: 300;
    color: var(--color-gold-light);
    line-height: 1;
  }

  .hero__stat-label {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.6);
    margin-top: 0.25rem;
    display: block;
  }

  /* Scroll hint */
  .hero__scroll-hint {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    opacity: 0;
    animation: fadeSlideUp 0.5s var(--ease-smooth) 1.5s forwards;
  }

  .hero__scroll-hint span {
    display: block;
    width: 1px;
    height: 48px;
    background: linear-gradient(to bottom, var(--color-gold), transparent);
    animation: scrollHint 2s ease-in-out infinite;
  }

  /* --- Responsive --- */
  @media (max-width: 768px) {
    .hero {
      min-height: auto;
      padding-top: 0;
    }

    .hero__inner {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .hero__content {
      text-align: center;
      padding-block: var(--space-xl);
      order: 1;
    }

    .hero__subtitle {
      margin-inline: auto;
    }

    .hero__actions {
      justify-content: center;
    }

    .hero__visual {
      order: 2;
      max-height: 50vh;
    }

    .hero__bg-text--bottom {
      display: none;
    }
  }

  /* Respect reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .hero {
      animation: none;
    }

    .hero__bg-text {
      animation: none;
    }

    .hero__eyebrow,
    .hero__title,
    .hero__subtitle,
    .hero__actions,
    .hero__visual,
    .hero__stat,
    .hero__scroll-hint {
      opacity: 1;
      animation: none;
    }

    .hero__orb {
      animation: none;
    }
  }
</style>
