---
interface Props {
  number: string;
  name: string;
  oneLiner: string;
  explanation: string;
  topics: string[];
  accentColor?: string;
}

const { number, name, oneLiner, explanation, topics, accentColor = 'gold' } = Astro.props;
const anchorId = number.replace('.', '-');
---

<article class="subcat" id={anchorId}>
  <div class="subcat__header">
    <span class={`subcat__number subcat__number--${accentColor}`}>{number}</span>
    <h3 class="subcat__name">{name}</h3>
  </div>
  <p class="subcat__oneliner">{oneLiner}</p>
  <p class="subcat__explanation">{explanation}</p>
  <ul class="subcat__topics">
    {topics.map((topic) => (
      <li>{topic}</li>
    ))}
  </ul>
</article>

<style>
  .subcat {
    padding-bottom: var(--space-3xl);
    margin-bottom: var(--space-xl);
    border-bottom: 1px solid var(--color-light-grey);
    scroll-margin-top: 100px;
  }

  .subcat:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }

  .subcat__header {
    display: flex;
    align-items: baseline;
    gap: var(--space-sm);
    margin-bottom: var(--space-md);
  }

  .subcat__number {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    flex-shrink: 0;
  }

  .subcat__number--gold { color: var(--color-gold); }
  .subcat__number--berry { color: var(--color-berry); }
  .subcat__number--teal { color: var(--color-teal-accent); }

  .subcat__name {
    font-family: var(--font-serif);
    font-size: clamp(1.3rem, 2.5vw, 1.6rem);
    color: var(--color-deep-teal);
    line-height: 1.3;
  }

  .subcat__oneliner {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.05rem;
    color: var(--color-warm-dark);
    border-left: 2px solid var(--color-gold);
    padding-left: var(--space-md);
    margin-bottom: var(--space-lg);
    line-height: 1.7;
    max-width: none;
  }

  .subcat__explanation {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--color-dark-grey);
    margin-bottom: var(--space-lg);
    max-width: none;
  }

  .subcat__topics {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
  }

  .subcat__topics li {
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--color-deep-teal);
    background: var(--color-off-white);
    border: 1px solid var(--color-light-grey);
    padding: 0.35rem 0.85rem;
    border-radius: 100px;
    white-space: nowrap;
  }
</style>
