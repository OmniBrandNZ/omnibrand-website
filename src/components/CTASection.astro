---

<section class="cta-section">
  <div class="container">
    <div class="cta-section__content">
      <h2 class="cta-section__title">Don't know where to start?</h2>
      <p class="cta-section__text">Book a free consultation and we'll make sure you get the package that suits your needs & your budget.</p>
      <a href="/contact" class="cta-section__button">Book a discovery call</a>
      <p class="cta-section__secondary">or <a href="/contact" class="cta-section__link">contact us</a></p>
    </div>
  </div>
</section>

<style>
  .cta-section {
    background-color: var(--color-accent);
    color: var(--color-white);
    padding-block: var(--space-3xl);
  }

  .cta-section__content {
    text-align: center;
  }

  .cta-section__title {
    font-family: var(--font-serif);
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    color: var(--color-white);
    margin-bottom: var(--space-md);
    letter-spacing: -0.01em;
  }

  .cta-section__text {
    color: var(--color-white);
    font-size: 1.05rem;
    line-height: 1.6;
    margin-bottom: var(--space-lg);
    max-width: 700px;
    margin-inline: auto;
  }

  .cta-section__button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 2rem;
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border-radius: var(--border-radius);
    background-color: var(--color-white);
    color: var(--color-accent);
    transition: all var(--transition-base);
  }

  .cta-section__button:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
  }

  .cta-section__secondary {
    color: var(--color-white);
    font-size: 0.95rem;
    margin-top: var(--space-md);
    margin-bottom: 0;
  }

  .cta-section__link {
    color: var(--color-white);
    text-decoration: none;
    border-bottom: 1px solid var(--color-white);
    transition: all var(--transition-base);
  }

  .cta-section__link:hover {
    border-bottom-color: transparent;
  }
</style>
