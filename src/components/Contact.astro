---
---

<section class="contact section" id="contact">
  <div class="container">
    <div class="contact__grid">
      <div class="contact__content">
        <p class="contact__eyebrow">Get Started</p>
        <h2 class="contact__title">Ready to build a brand you're proud of?</h2>
        <p class="contact__text">
          Book a free discovery call to chat about your brand, your goals,
          and how we can help bring your vision to life.
        </p>
        <div class="contact__details">
          <div class="contact__detail">
            <span class="contact__detail-icon" aria-hidden="true">✦</span>
            <div>
              <strong>Free Discovery Call</strong>
              <p>30 minutes to explore how we can help</p>
            </div>
          </div>
          <div class="contact__detail">
            <span class="contact__detail-icon" aria-hidden="true">✦</span>
            <div>
              <strong>Tailored Approach</strong>
              <p>Every project is scoped to your needs</p>
            </div>
          </div>
          <div class="contact__detail">
            <span class="contact__detail-icon" aria-hidden="true">✦</span>
            <div>
              <strong>NZ Based</strong>
              <p>Working with clients locally and globally</p>
            </div>
          </div>
        </div>
      </div>
      <div class="contact__cta-col">
        <div class="contact__card">
          <h3 class="contact__card-title">Book a Discovery Call</h3>
          <p class="contact__card-text">
            Let's have a no-obligation chat about your brand and explore
            how we can work together.
          </p>
          <a href="mailto:hello@omnibrand.co.nz" class="btn btn--primary contact__btn">
            Get in Touch
          </a>
          <p class="contact__card-alt">
            or email us directly at<br/>
            <a href="mailto:hello@omnibrand.co.nz" class="contact__email">hello@omnibrand.co.nz</a>
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .contact {
    background-color: var(--color-white);
  }

  .contact__grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: var(--space-3xl);
    align-items: start;
  }

  .contact__eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-bottom: var(--space-sm);
  }

  .contact__title {
    margin-bottom: var(--space-md);
  }

  .contact__text {
    color: var(--color-warm-neutral);
    font-size: 1.05rem;
    line-height: 1.8;
    margin-bottom: var(--space-xl);
  }

  .contact__details {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .contact__detail {
    display: flex;
    gap: var(--space-sm);
    align-items: flex-start;
  }

  .contact__detail-icon {
    color: var(--color-gold);
    font-size: 0.85rem;
    margin-top: 0.15rem;
    flex-shrink: 0;
  }

  .contact__detail strong {
    display: block;
    color: var(--color-deep-teal);
    font-size: 0.95rem;
    margin-bottom: 0.15rem;
  }

  .contact__detail p {
    font-size: 0.875rem;
    color: var(--color-warm-neutral);
    line-height: 1.5;
  }

  .contact__card {
    background: var(--color-off-white);
    border: 1px solid var(--color-light-grey);
    border-radius: 20px;
    padding: var(--space-xl);
    text-align: center;
  }

  .contact__card-title {
    font-size: 1.5rem;
    margin-bottom: var(--space-sm);
  }

  .contact__card-text {
    color: var(--color-warm-neutral);
    font-size: 0.95rem;
    line-height: 1.7;
    margin-bottom: var(--space-lg);
    margin-inline: auto;
  }

  .contact__btn {
    width: 100%;
    justify-content: center;
    margin-bottom: var(--space-md);
  }

  .contact__card-alt {
    font-size: 0.85rem;
    color: var(--color-warm-neutral);
    line-height: 1.6;
  }

  .contact__email {
    color: var(--color-berry);
    font-weight: 600;
    transition: color var(--transition-fast);
  }

  .contact__email:hover {
    color: var(--color-berry-light);
  }

  @media (max-width: 768px) {
    .contact__grid {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }
  }
</style>
