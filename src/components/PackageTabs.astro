---
---

<section class="packages section" id="packages">
  <div class="container">
    <div class="packages__tabs" role="tablist" aria-label="Service packages">
      <button class="packages__tab packages__tab--active" role="tab" aria-selected="true" aria-controls="panel-corporate" id="tab-corporate">Corporate Brand Design</button>
      <button class="packages__tab" role="tab" aria-selected="false" aria-controls="panel-substack" id="tab-substack">Substack Brand Design</button>
      <button class="packages__tab" role="tab" aria-selected="false" aria-controls="panel-website" id="tab-website">Website Design</button>
    </div>

    <!-- Corporate Brand Design -->
    <div class="packages__panel packages__panel--active" role="tabpanel" id="panel-corporate" aria-labelledby="tab-corporate">
      <div class="packages__layout">
        <div class="packages__left">
          <div class="packages__info">
            <p class="packages__eyebrow">Our signature package</p>
            <h2 class="packages__title">Corporate Brand Design</h2>
            <p class="packages__desc">
              Our Corporate Identity package starts with a thorough strategy session, includes multiple rounds of design & revision and ends with a beautiful brand book.
            </p>
            <p class="packages__desc">
              Work with a trusted brand expert with over a decade of experience and a track record of launching more than 100 successful brands. We bring a strategic approach, meticulous attention to detail, and a commitment to delivering high-quality results.
            </p>
          </div>
          <div class="packages__features">
          <div class="packages__feature-card">
            <div class="packages__feature-icon">✎</div>
            <h3 class="packages__feature-title">Brand Design</h3>
            <p class="packages__feature-desc">1:1 design service with multiple revision rounds</p>
          </div>
          <div class="packages__feature-card">
            <div class="packages__feature-icon">⏱</div>
            <h3 class="packages__feature-title">6 - 8 weeks</h3>
            <p class="packages__feature-desc">From discovery session to beautiful brandbook</p>
          </div>
          <div class="packages__feature-card">
            <div class="packages__feature-icon">◆</div>
            <h3 class="packages__feature-title">Strategy</h3>
            <p class="packages__feature-desc">Your brand is built on a foundation of strategy</p>
          </div>
          </div>
          <div class="packages__cta">
            <a href="#contact" class="btn btn--primary">Corporate Brand Design</a>
          </div>
        </div>
        <div class="packages__image">
          <img src="/images/tabs/corporate-brand-design.png" alt="Corporate Brand Design example" class="packages__image-img" />
        </div>
      </div>
    </div>

    <!-- Substack Brand Design -->
    <div class="packages__panel" role="tabpanel" id="panel-substack" aria-labelledby="tab-substack" hidden>
      <div class="packages__layout">
        <div class="packages__left">
          <div class="packages__info">
            <p class="packages__eyebrow">Our <em>famous</em> Substack package</p>
            <h2 class="packages__title">Substack Publication Design</h2>
            <p class="packages__desc">
              This package was designed specifically with Substack writers in mind. It's streamlined to help you launch your publication quickly & confidently.
            </p>
            <p class="packages__desc">
              Get your brand designed & launched in just 14 days. This streamlined design package includes everything you need to look amazing on Substack.
            </p>
          </div>
          <div class="packages__features">
          <div class="packages__feature-card">
            <div class="packages__feature-icon">✎</div>
            <h3 class="packages__feature-title">Brand Design</h3>
            <p class="packages__feature-desc">1:1 design service with multiple revision rounds</p>
          </div>
          <div class="packages__feature-card">
            <div class="packages__feature-icon">⏱</div>
            <h3 class="packages__feature-title">14 days</h3>
            <p class="packages__feature-desc">A streamlined process from discovery to launch</p>
          </div>
          <div class="packages__feature-card">
            <div class="packages__feature-icon">✓</div>
            <h3 class="packages__feature-title">Launch Support</h3>
            <p class="packages__feature-desc">Screenshots, email & video support for your setup</p>
          </div>
          </div>
          <div class="packages__cta">
            <a href="#contact" class="btn btn--primary">Substack Publication Design</a>
          </div>
        </div>
        <div class="packages__image">
          <img src="/images/tabs/substack-brand-design-agonist.jpg" alt="Substack Brand Design example" class="packages__image-img" />
        </div>
      </div>
    </div>

    <!-- Website Design -->
    <div class="packages__panel" role="tabpanel" id="panel-website" aria-labelledby="tab-website" hidden>
      <div class="packages__layout">
        <div class="packages__left">
          <div class="packages__info">
            <p class="packages__eyebrow">Our signature package</p>
            <h2 class="packages__title">Website Design</h2>
            <p class="packages__desc">
              If you are starting a business, this package is perfect for you. It includes corporate branding, professional website design, hosting & maintenance and more – all in one comprehensive package.
            </p>
            <p class="packages__desc">
              Work with a trusted expert with over a decade of experience and a track record of launching more than 100 successful brands. We bring a strategic approach, meticulous attention to detail, and a commitment to delivering high-quality results.
            </p>
          </div>
          <div class="packages__features">
          <div class="packages__feature-card">
            <div class="packages__feature-icon">✎</div>
            <h3 class="packages__feature-title">Brand Design</h3>
            <p class="packages__feature-desc">1:1 design service with multiple revision rounds</p>
          </div>
          <div class="packages__feature-card">
            <div class="packages__feature-icon">⏱</div>
            <h3 class="packages__feature-title">90 Days</h3>
            <p class="packages__feature-desc">From discovery session to website Launch</p>
          </div>
          <div class="packages__feature-card">
            <div class="packages__feature-icon">◆</div>
            <h3 class="packages__feature-title">Strategy</h3>
            <p class="packages__feature-desc">Built on a solid foundation of strategy</p>
          </div>
          </div>
          <div class="packages__cta">
            <a href="#contact" class="btn btn--primary">Website Design</a>
          </div>
        </div>
        <div class="packages__image">
          <img src="/images/tabs/website-design-alembic-partners-tall.jpg" alt="Website Design example" class="packages__image-img" />
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const tabs = document.querySelectorAll('.packages__tab');
  const panels = document.querySelectorAll('.packages__panel');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      tabs.forEach(t => {
        t.classList.remove('packages__tab--active');
        t.setAttribute('aria-selected', 'false');
      });
      panels.forEach(p => {
        p.classList.remove('packages__panel--active');
        p.hidden = true;
      });

      tab.classList.add('packages__tab--active');
      tab.setAttribute('aria-selected', 'true');

      const panelId = tab.getAttribute('aria-controls');
      const panel = document.getElementById(panelId!);
      if (panel) {
        panel.hidden = false;
        panel.classList.add('packages__panel--active');
      }
    });
  });
</script>

<style>
  .packages {
    background-color: var(--color-off-white);
  }

  /* Tabs */
  .packages__tabs {
    display: flex;
    justify-content: center;
    gap: var(--space-xs);
    margin-bottom: var(--space-xl);
    flex-wrap: wrap;
  }

  .packages__tab {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.875rem 2rem;
    border-radius: var(--border-radius);
    color: var(--color-deep-teal);
    background: transparent;
    border: 1.5px solid var(--color-mid-grey);
    cursor: pointer;
    transition: all var(--transition-base);
  }

  .packages__tab:hover {
    border-color: var(--color-deep-teal);
    background-color: rgba(20, 40, 45, 0.04);
  }

  .packages__tab--active {
    background-color: var(--color-deep-teal);
    color: var(--color-white);
    border-color: var(--color-deep-teal);
  }

  .packages__tab--active:hover {
    background-color: var(--color-deep-teal);
    color: var(--color-white);
  }

  /* Panels */
  .packages__panel {
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.4s var(--ease-smooth), transform 0.4s var(--ease-smooth);
  }

  .packages__panel--active {
    opacity: 1;
    transform: translateY(0);
  }

  /* Layout */
  .packages__layout {
    display: grid;
    grid-template-columns: 1.4fr 0.6fr;
    gap: var(--space-xl);
    align-items: start;
  }

  /* Info side */
  .packages__info {
    width: 100%;
  }

  .packages__eyebrow {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-bottom: var(--space-sm);
  }

  .packages__eyebrow em {
    font-style: italic;
    text-transform: none;
    letter-spacing: 0.05em;
  }

  .packages__title {
    margin-bottom: var(--space-md);
  }

  .packages__desc {
    color: var(--color-warm-neutral, var(--color-dark-grey));
    font-size: 1.05rem;
    line-height: 1.8;
    margin-bottom: var(--space-sm);
    max-width: none;
  }

  /* Image */
  .packages__image {
    width: 100%;
    height: auto;
    min-height: 650px;
    background-color: var(--color-off-white);
    border-radius: 12px;
    margin-bottom: 0;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .packages__image-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  /* Feature cards */
  .packages__features {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
    margin-top: var(--space-lg);
  }

  .packages__feature-card {
    background: var(--color-white);
    border: 2px solid var(--color-light-grey);
    border-radius: 8px;
    padding: var(--space-lg);
    transition: all var(--transition-base);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    min-height: 200px;
    justify-content: center;
  }

  .packages__feature-card:hover {
    border-color: var(--color-mid-grey);
    box-shadow: 0 8px 32px rgba(20, 41, 46, 0.1);
    transform: translateY(-4px);
  }

  .packages__feature-icon {
    font-size: 1.5rem;
    color: var(--color-gold);
    margin-bottom: var(--space-md);
    line-height: 1;
    opacity: 0.8;
  }

  .packages__feature-title {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    color: var(--color-deep-teal);
    margin-bottom: 0.75rem;
    font-weight: 600;
  }

  .packages__feature-desc {
    font-size: 0.95rem;
    color: var(--color-warm-neutral, var(--color-dark-grey));
    line-height: 1.7;
    letter-spacing: 0.3px;
  }

  /* CTA */
  .packages__cta {
    margin-top: var(--space-lg);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .packages__tabs {
      flex-direction: column;
      align-items: stretch;
    }

    .packages__tab {
      text-align: center;
    }

    .packages__layout {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
    }
  }
</style>
